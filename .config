# === 目标平台（玩客云 S805）===
CONFIG_TARGET_amlogic=y
CONFIG_TARGET_amlogic_meson8b=y
CONFIG_TARGET_amlogic_meson8b_DEVICE_onecloud=y

# === 基础系统 ===
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_KERNEL_BUILD_USER="openwrt"
CONFIG_KERNEL_BUILD_DOMAIN="onecloud"

CONFIG_PACKAGE_luci-app-xlnetacc=n
CONFIG_PACKAGE_luci-app-vlmcsd=n
CONFIG_PACKAGE_luci-app-zerotier=n
CONFIG_PACKAGE_luci-app-ipsec-vpnd=n
CONFIG_PACKAGE_luci-app-unblockmusic=n
CONFIG_PACKAGE_luci-app-wireguard=n
CONFIG_PACKAGE_luci-app-adbyby-plus=n
CONFIG_PACKAGE_nlbwmon=n
CONFIG_PACKAGE_luci-app-nlbwmon=n
CONFIG_PACKAGE_luci-app-statistics=n
CONFIG_PACKAGE_luci-app-webadmin=n
CONFIG_PACKAGE_luci-app-wrtbwmon=n
CONFIG_PACKAGE_luci-app-wol=n
CONFIG_PACKAGE_luci-app-ddns=n
CONFIG_PACKAGE_luci-app-vsftpd=n
CONFIG_PACKAGE_luci-app-turboacc=n
CONFIG_PACKAGE_luci-app-upnp=n

CONFIG_TARGET_KERNEL_PARTSIZE=128
CONFIG_TARGET_ROOTFS_PARTSIZE=600

# === IPv6 全协议支持 ===
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_kmod-ipv6=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_luci-proto-ipv6=y

# 关闭无用组件（节省空间）
#（默认不选即可，确保不要选以下）
# CONFIG_PACKAGE_v2ray-core is not set
# CONFIG_PACKAGE_kcptun-client is not set
# CONFIG_PACKAGE_mosdns is not set
# CONFIG_PACKAGE_naiveproxy is not set
# CONFIG_PACKAGE_tuic-client is not set

# === 性能优化 ===
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-cake=y


# SS+
CONFIG_PACKAGE_luci-app-ssr-plus=y  # 
# 核心协议引擎 (Xray 包含 VMess/VLESS/Trojan/SS) 
CONFIG_PACKAGE_xray-core=y  # 
CONFIG_PACKAGE_xray-geodata=y  # 
# Hysteria2 (独立核心) 
CONFIG_PACKAGE_hysteria=y  # 
CONFIG_PACKAGE_tuic-client=y  # 
CONFIG_PACKAGE_ca-bundle=y   # 

# 解压文件
CONFIG_PACKAGE_xz=y
CONFIG_PACKAGE_xz-utils=y
CONFIG_PACKAGE_liblzma=y

CONFIG_PACKAGE_luci-app-ttyd=y

CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_samba4-server=y  # Samba 文件共享
CONFIG_PACKAGE_luci-app-samba4=y  # Samba 的 LuCI 支持
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_autosamba=y

CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_blkid=y

CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-ntfs=y

# ===== USB存储支持 =====
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y

CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-scsi-core=y


